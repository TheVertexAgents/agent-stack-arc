# AgentStack - Environment Configuration

# ==========================================
# 1. CIRCLE DEVELOPER CONSOLE CREDENTIALS
# Login at https://console.circle.com/
# Go to "API & Client Keys" to generate these
# ==========================================
CIRCLE_API_KEY="ENTER_YOUR_API_KEY_HERE"
CIRCLE_ENTITY_SECRET="ENTER_YOUR_32_BYTE_ENTITY_SECRET_HERE"

# NOTE: CIRCLE_USER_TOKEN is only needed for User-Controlled Wallets.
# Since we are building an automated backend orchestrator, Developer-Controlled
# Wallets (using the Entity Secret) are better. You can leave this blank.
CIRCLE_USER_TOKEN=""

# ==========================================
# 2. ARC L1 TESTNET DETAILS (Public Info)
# Arc uses USDC as the native gas token.
# ==========================================
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_CHAIN_ID="5042002"
# On Arc, USDC is a native system contract used for gas, located here:
USDC_CONTRACT_ADDRESS="0x3600000000000000000000000000000000000000"
ARC_EXPLORER_URL="https://testnet.arcscan.app"

# ==========================================
# 3. AGENT WALLETS (Private Keys)
# Generate via Circle SDK or export from MetaMask
# IMPORTANT: Fund the USER/ORCHESTRATOR wallet via the Arc Testnet Faucet!
# ==========================================
USER_PRIVATE_KEY="ENTER_USER_PK_HERE"
ORCHESTRATOR_PRIVATE_KEY="ENTER_ORCHESTRATOR_PK_HERE"
WORKER_A_PRIVATE_KEY="ENTER_WORKER_A_PK_HERE"

# ==========================================
# 4. SERVER & HACKATHON CONFIG
# ==========================================
PORT=3000
NODE_ENV="development"
WORKER_FEE_USDC="0.002"
