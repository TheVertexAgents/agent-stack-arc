# AgentStack - Environment Configuration

# --- Circle API ---
# Hard Blocker: Create account at https://console.circle.com/
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_USER_TOKEN=

# --- Arc L1 ---
ARC_RPC_URL=https://rpc.arc-l1.circle.com
ARC_CHAIN_ID=
USDC_CONTRACT_ADDRESS=

# --- Agent Wallets ---
# 3 Wallets needed (User, Orchestrator, Worker)
USER_PRIVATE_KEY=
ORCHESTRATOR_PRIVATE_KEY=
WORKER_A_PRIVATE_KEY=

# --- Server Config ---
PORT=3000
NODE_ENV=development
